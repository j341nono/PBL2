# MySQL connection (use PlanetScale, Railway, or any cloud MySQL)
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@host:3306/pbl2

# Or use individual vars:
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=pbl2

# Session secret - must be at least 32 characters
SESSION_SECRET=change_this_to_a_random_32_character_string!!
